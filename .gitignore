# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js Build Output
/.next/
/out/
/build

# Testing & Coverage
/coverage
.nyc_output

# Environment Secrets (CRITICAL)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# OS Metadata
.DS_Store
Thumbs.db
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Large Binary Assets & Mobile Builds (Vercel-Friendly)
/public/downloads/*.apk
/public/downloads/*.ipa
*.zip
*.tar.gz

# Local Tooling
.hf/
.python-version
.venv/
.gemini/
.claude/

# Branding Assets (Source Folders)
/Roamly_Logo_PNGs/
/Roamly_Logo_Transparent_PNGs/

# Firebase
.firebase/
firebase-debug.log*
.firebaserc
.convo/